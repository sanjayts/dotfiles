#!/usr/bin/env bash
# Pre-commit hook: scan staged content with gitleaks before allowing the commit.
# Install from repo root with: ./hooks/install
set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "error: gitleaks not found on PATH. Install with: brew install gitleaks" >&2
  exit 1
fi

exec gitleaks git --staged --redact --no-banner
