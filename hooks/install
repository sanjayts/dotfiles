#!/usr/bin/env bash
# Install the repo's git hooks into .git/hooks for this clone.
# Safe to re-run; uses symlinks so future hook edits are picked up automatically.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# On machines with a global core.hooksPath (e.g. corp-managed laptops that
# chain hooks centrally), git ignores .git/hooks entirely. Scope the default
# behaviour back to this one repo without touching the global config.
if [[ "$(git config --get core.hooksPath 2>/dev/null || true)" != ".git/hooks" ]]; then
  git config --local core.hooksPath .git/hooks
  echo "set local core.hooksPath = .git/hooks"
fi

chmod +x hooks/pre-commit
ln -sf ../../hooks/pre-commit .git/hooks/pre-commit
echo "installed: .git/hooks/pre-commit -> hooks/pre-commit"

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "warning: gitleaks is not installed. Run: brew install gitleaks" >&2
fi
